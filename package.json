{
  "name": "leetcode-import-pipeline",
  "version": "0.1.0",
  "description": "Standalone LeetCode-CN import pipeline that emits normalized JSON data and reports.",
  "type": "module",
  "private": true,
  "bin": {
    "leetcode-import-pipeline": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tmp coverage",
    "example": "npm run import:leetcode-cn -- --source examples/leetcode-cn --out tmp/leetcode-cn --pretty --verbose",
    "import:leetcode-cn": "tsx src/cli.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "leetcode",
    "import",
    "pipeline",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.7",
    "eslint": "^9.30.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
